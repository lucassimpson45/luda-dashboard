# ─── Retell AI ───────────────────────────────────────────────
# Get from: https://app.retellai.com → Settings → API Keys
RETELL_API_KEY=your_retell_api_key_here

# Receptionist (inbound) agent
# Get from: Retell dashboard → Agents → your agent → copy ID
RETELL_AGENT_ID=your_receptionist_agent_id_here

# Outbound / sales agent (separate from receptionist)
RETELL_OUTBOUND_AGENT_ID=your_outbound_agent_id_here

# ─── N8N Webhooks ────────────────────────────────────────────
# Secret must match the `secret` field in N8N HTTP request bodies
N8N_WEBHOOK_SECRET=your_shared_webhook_secret_here

# ─── App ────────────────────────────────────────────────────
# Client portal passwords live in Supabase `public.clients` (create rows in Admin).

# Admin portal (/admin)
ADMIN_PASSWORD=lucben225

# Production URL (webhooks, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Supabase (optional on local dev: falls back to .data/webhook-store.json) ───
# On Vercel, set both for the clients table and other Supabase usage (quotes/reviews UI uses Airtable).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Airtable (quotes + reviews tabs read from here) ─────────────────────────
# Personal access token: https://airtable.com/create/tokens — scope: data.records:read on the base
AIRTABLE_API_TOKEN=your_airtable_pat_here
AIRTABLE_BASE_ID=app9ueTFqFsszU9x3
AIRTABLE_QUOTES_TABLE_ID=tblNL3lX8GWJDRS3h
AIRTABLE_REVIEWS_TABLE_ID=tbl7da5zdLNagcc2e
